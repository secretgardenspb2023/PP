# PoiskPlant — environment template. Copy to .env and fill in.
# NEVER commit the real .env. Secrets are provided by the client per the
# "Инструкции по регистрации внешних сервисов" doc.

# ---- Django ----
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-dev-only
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
# Comma-separated origins allowed to call the API from the browser
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Frontend base URL used in verification / password-reset emails
FRONTEND_URL=http://localhost:3000
# Secure flag for the refresh-token cookie (default: true unless DEBUG)
# AUTH_COOKIE_SECURE=false

# ---- PostgreSQL (matches client dump: PG 17) ----
POSTGRES_DB=poiskplant
POSTGRES_USER=poiskplant
POSTGRES_PASSWORD=poiskplant-dev
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# django-environ reads this single URL:
DATABASE_URL=postgres://poiskplant:poiskplant-dev@postgres:5432/poiskplant

# ---- Redis (cache, Celery broker, rate-limit) ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---- Elasticsearch (russian morphology search) ----
ELASTICSEARCH_URL=http://elasticsearch:9200

# ---- S3 / Yandex Object Storage (bucket created by client) ----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=https://storage.yandexcloud.net
AWS_S3_REGION_NAME=ru-central1

# ---- imgproxy (HMAC-signed image URLs) ----
IMGPROXY_KEY=
IMGPROXY_SALT=
IMGPROXY_BASE_URL=http://imgproxy:8080

# ---- Email (Yandex Mail for domain, SMTP) ----
EMAIL_HOST=smtp.yandex.ru
EMAIL_PORT=465
EMAIL_USE_SSL=true
EMAIL_HOST_USER=noreply@poiskplant.ru
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=PoiskPlant <noreply@poiskplant.ru>

# ---- OAuth providers (Stage 3) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
VK_APP_ID=
VK_SERVICE_TOKEN=
VK_SECURE_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# ---- Yandex SmartCaptcha ----
SMARTCAPTCHA_CLIENT_KEY=
SMARTCAPTCHA_SERVER_KEY=

# ---- Monitoring ----
SENTRY_DSN=

# ---- Production deploy (infra/docker-compose.prod.yml) ----
DOMAIN=poiskplant.ru
STAGING_DOMAIN=staging.poiskplant.ru
# Encrypted backups → S3 (infra/backup/backup.sh)
BACKUP_S3_BUCKET=
BACKUP_GPG_PASSPHRASE=
